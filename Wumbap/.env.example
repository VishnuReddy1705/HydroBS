# HydroBS backend configuration — export these as environment variables in every
# non-local deployment. Local development falls back to the defaults in application.properties.

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/water_monitor_db
DB_USERNAME=postgres
DB_PASSWORD=change-me

# --- JPA/Hibernate ---
# Use 'validate' in production once entity<->migration parity is confirmed.
DDL_AUTO=update

# --- Security ---
# 256-bit Base64 secret. Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-strong-base64-secret
JWT_EXPIRATION_MS=900000

# --- CORS / Frontend ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173

# --- Bootstrap super admin (created only if it does not already exist) ---
SUPER_ADMIN_EMAIL=admin@gmail.com
SUPER_ADMIN_PASSWORD=change-me
